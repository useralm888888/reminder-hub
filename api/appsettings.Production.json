{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=reminders;Username=reminder;Password=reminder"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "ReminderProcessor": {
    "PollingIntervalSeconds": 15
  },
  "ReminderDelivery": {
    "LogFilePath": "logs/reminders.log"
  },
  "HealthChecks": {
    "Enabled": true
  },
  "Cors": {
    "AllowedOrigins": []
  }
}
